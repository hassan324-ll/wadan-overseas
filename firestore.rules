rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {

match /pages/{document} {
  allow read: if true;
  allow write: if request.auth != null;
}

match /services/{document} {
  allow read: if true;
  allow write: if request.auth != null;
}

match /sections/{document} {
  allow read: if true;
  allow write: if request.auth != null;
}

}
}
